generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum KlantType {
  direct
  reseller
  intern
}

enum FactuurStatus {
  te_doen
  gefactureerd
  betaald
}

// Voor klanten bij overheden/gemeentes: G-Bit moet daar eerst als
// leverancier geregistreerd zijn vóór er gefactureerd kan worden.
enum LeverancierStatus {
  nvt
  vereist
  aangevraagd
  geregistreerd
}

// Projecten = klantdossier (naslagwerk), géén taakbeheer. Zie
// docs/superpowers/specs/2026-07-10-projecten-design.md.
enum ProjectStatus {
  gepland
  actief
  gepauzeerd
  afgerond
}

enum NotitieType {
  notitie
  verslag
}

model Klant {
  id                String            @id @default(cuid())
  naam              String            @unique
  type              KlantType         @default(direct)
  vatNumber         String?
  adres             String?
  stad              String?
  postcode          String?
  land              String?           @default("Belgium")
  notities          String?
  leverancierStatus LeverancierStatus @default(nvt)
  comanageId        String?
  nomeoId           String?           @unique
  contacten         Contact[]
  sites             Site[]            @relation("FactuurKlant")
  eindklantSites    Site[]            @relation("EindKlant")
  beheerSites       Site[]            @relation("BeheerKlant")
  domeinen       Domein[]
  abonnementen   Abonnement[]
  projecten      Project[]
  accounts       Account[]
  portalAccounts PortalAccount[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Login voor het reseller-portaal (/portal) — volledig gescheiden van de
// interne Auth.js-login: een portal-sessie geeft NOOIT toegang tot het CRM.
// Wachtwoord = scrypt-hash (salt:hash), zie src/lib/portal-auth.ts.
model PortalAccount {
  id             String    @id @default(cuid())
  email          String    @unique
  wachtwoordHash String
  actief         Boolean   @default(true)
  laatsteLogin   DateTime?
  klant          Klant     @relation(fields: [klantId], references: [id], onDelete: Cascade)
  klantId        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Project {
  id           String          @id @default(cuid())
  naam         String
  status       ProjectStatus   @default(actief)
  omschrijving String?
  startDatum   DateTime?
  eindDatum    DateTime?
  klant        Klant           @relation(fields: [klantId], references: [id], onDelete: Cascade)
  klantId      String
  notities     ProjectNotitie[]
  accounts     Account[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ProjectNotitie {
  id        String      @id @default(cuid())
  type      NotitieType @default(notitie)
  titel     String
  // Datum van de meeting/notitie zelf — los van wanneer ze werd ingetypt.
  datum     DateTime
  inhoud    String
  auteur    String?
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// Logins van de klant (site-admin, mailinglijst, ...). Hangt aan de klant
// (logins overleven projecten), optioneel gelinkt aan een project.
// Wachtwoord staat als tekst in de DB — bewuste keuze Bjorn (2026-07-10);
// de UI toont het verborgen en het rapport-script geeft het NOOIT uit.
model Account {
  id             String   @id @default(cuid())
  dienst         String
  url            String?
  gebruikersnaam String?
  wachtwoord     String?
  notitie        String?
  klant          Klant    @relation(fields: [klantId], references: [id], onDelete: Cascade)
  klantId        String
  project        Project? @relation(fields: [projectId], references: [id])
  projectId      String?
}

model Contact {
  id       String  @id @default(cuid())
  naam     String
  email    String?
  telefoon String?
  rol      String?
  klant    Klant   @relation(fields: [klantId], references: [id], onDelete: Cascade)
  klantId  String
}

model Site {
  id             String   @id @default(cuid())
  naam           String
  pleskStatus    String?
  verbruikMB     Float?
  hostingprijs   Float?
  notities       String?
  factuurKlant   Klant    @relation("FactuurKlant", fields: [factuurKlantId], references: [id])
  factuurKlantId String
  eindKlant      Klant?   @relation("EindKlant", fields: [eindKlantId], references: [id])
  eindKlantId    String?
  // Wie het beheer doet als dat niet de factuurklant is (bv. Bianca die enkel
  // beheert: factuur gaat rechtstreeks naar de eindklant, zij beheert).
  beheerKlant    Klant?   @relation("BeheerKlant", fields: [beheerKlantId], references: [id])
  beheerKlantId  String?
  domeinen       Domein[]
}

model Domein {
  id               String    @id @default(cuid())
  naam             String    @unique
  tld              String?
  expireDate       DateTime?
  registrationDate DateTime?
  autoRenew        Boolean   @default(true)
  status           String?
  inkoopPrijs      Float?
  verkoopPrijs     Float?
  notities         String?
  // Live-check (scripts/live-check.ts): waar draait dit domein echt?
  liveIp            String?
  liveWaar          String?   // "onze Plesk" of duiding van het externe adres
  opOnzeServer      Boolean?
  httpStatus        String?   // statuscode of "onbereikbaar"
  cms               String?   // bv. "WordPress 6.7"
  elementorPro      Boolean?  // prisma/check-elementor.ts: draait de site op Elementor Pro?
  registratieStatus String?   // whois/RDAP: AVAILABLE = vervallen én weer vrij
  registrar         String?   // whois/RDAP: waar het domein geregistreerd is (enkel buiten ons Nomeo)
  laatsteLiveCheck  DateTime?
  // Nomeo-vlaggen (sync) + domeincontacten (registrant/on-site/admin/...).
  nomeoExpired       Boolean?
  nomeoCancelled     Boolean?
  nomeoContacts      Json?
  nomeoContactsCheck DateTime?
  nomeoId          String?   @unique
  klant            Klant?    @relation(fields: [klantId], references: [id])
  klantId          String?
  site             Site?     @relation(fields: [siteId], references: [id])
  siteId           String?
}

model Abonnement {
  id              String          @id @default(cuid())
  omschrijving    String?
  jaarbedrag      Float
  renewalDate     DateTime
  klant           Klant           @relation(fields: [klantId], references: [id])
  klantId         String
  factuurMomenten FactuurMoment[]
}

// Kleine key-value-opslag voor app-metadata (bv. tijdstip laatste Nomeo-sync).
model Instelling {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model FactuurMoment {
  id           String        @id @default(cuid())
  actieDatum   DateTime
  bedrag       Float
  status       FactuurStatus @default(te_doen)
  comanageRef  String?
  abonnement   Abonnement    @relation(fields: [abonnementId], references: [id], onDelete: Cascade)
  abonnementId String
}
