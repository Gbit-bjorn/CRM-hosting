generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum KlantType {
  direct
  reseller
  intern
}

enum FactuurStatus {
  te_doen
  gefactureerd
  betaald
}

// Voor klanten bij overheden/gemeentes: G-Bit moet daar eerst als
// leverancier geregistreerd zijn vóór er gefactureerd kan worden.
enum LeverancierStatus {
  nvt
  vereist
  aangevraagd
  geregistreerd
}

model Klant {
  id                String            @id @default(cuid())
  naam              String            @unique
  type              KlantType         @default(direct)
  vatNumber         String?
  adres             String?
  stad              String?
  postcode          String?
  land              String?           @default("Belgium")
  notities          String?
  leverancierStatus LeverancierStatus @default(nvt)
  comanageId        String?
  nomeoId           String?           @unique
  contacten         Contact[]
  sites             Site[]            @relation("FactuurKlant")
  eindklantSites    Site[]            @relation("EindKlant")
  beheerSites       Site[]            @relation("BeheerKlant")
  domeinen       Domein[]
  abonnementen   Abonnement[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Contact {
  id       String  @id @default(cuid())
  naam     String
  email    String?
  telefoon String?
  rol      String?
  klant    Klant   @relation(fields: [klantId], references: [id], onDelete: Cascade)
  klantId  String
}

model Site {
  id             String   @id @default(cuid())
  naam           String
  pleskStatus    String?
  verbruikMB     Float?
  hostingprijs   Float?
  notities       String?
  factuurKlant   Klant    @relation("FactuurKlant", fields: [factuurKlantId], references: [id])
  factuurKlantId String
  eindKlant      Klant?   @relation("EindKlant", fields: [eindKlantId], references: [id])
  eindKlantId    String?
  // Wie het beheer doet als dat niet de factuurklant is (bv. Bianca die enkel
  // beheert: factuur gaat rechtstreeks naar de eindklant, zij beheert).
  beheerKlant    Klant?   @relation("BeheerKlant", fields: [beheerKlantId], references: [id])
  beheerKlantId  String?
  domeinen       Domein[]
}

model Domein {
  id               String    @id @default(cuid())
  naam             String    @unique
  tld              String?
  expireDate       DateTime?
  registrationDate DateTime?
  autoRenew        Boolean   @default(true)
  status           String?
  inkoopPrijs      Float?
  verkoopPrijs     Float?
  notities         String?
  nomeoId          String?   @unique
  klant            Klant?    @relation(fields: [klantId], references: [id])
  klantId          String?
  site             Site?     @relation(fields: [siteId], references: [id])
  siteId           String?
}

model Abonnement {
  id              String          @id @default(cuid())
  omschrijving    String?
  jaarbedrag      Float
  renewalDate     DateTime
  klant           Klant           @relation(fields: [klantId], references: [id])
  klantId         String
  factuurMomenten FactuurMoment[]
}

// Kleine key-value-opslag voor app-metadata (bv. tijdstip laatste Nomeo-sync).
model Instelling {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model FactuurMoment {
  id           String        @id @default(cuid())
  actieDatum   DateTime
  bedrag       Float
  status       FactuurStatus @default(te_doen)
  comanageRef  String?
  abonnement   Abonnement    @relation(fields: [abonnementId], references: [id], onDelete: Cascade)
  abonnementId String
}
